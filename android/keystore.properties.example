# Release signing config for Google Play.
# 1. Copy this file to: android/keystore.properties
# 2. Generate your keystore (run from the android/ folder):
#      keytool -genkey -v -keystore motive-upload.keystore \
#        -alias motive -keyalg RSA -keysize 2048 -validity 10000
# 3. Fill in the values below.
# 4. NEVER commit keystore.properties or the .keystore file. Back them up safely —
#    losing them means you can't ship updates (unless using Play App Signing).

storeFile=motive-upload.keystore
storePassword=CHANGE_ME
keyAlias=motive
keyPassword=CHANGE_ME
